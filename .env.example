# Root .env — verwendet von docker-compose.yml und docker-compose.dev.yml
# Kopiere diese Datei zu .env und fülle die Werte aus.
# NIEMALS eine .env-Datei mit echten Secrets committen!

# --- Datenbank ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me         # z.B. openssl rand -base64 24
POSTGRES_DB=bundesrepublik

# --- Backend ---
# Mindestens 32 Zeichen, z.B.: openssl rand -hex 32
SECRET_KEY=
# Starkes Passwort für die Admin-API (Basic-Auth):
ADMIN_PASSWORD=                     # z.B. openssl rand -base64 24
DEBUG=false
