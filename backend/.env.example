# --- Lokale Entwicklung (Standard) ---
#
# Geheimnisse für Produktion (niemals committen):
#   SECRET_KEY — mindestens 32 Bytes Zufall, z. B. Hex (64 Zeichen):
#     openssl rand -hex 32
#   Passwörter (POSTGRES_PASSWORD, ADMIN_PASSWORD, SMTP_PASSWORD):
#     openssl rand -base64 24
#     oder: pwgen -s 32 1
#   Passphrase in DATABASE_URL dann escapen (% → %25 usw. bei Sonderzeichen).

# Datenbank (PostgreSQL mit asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bundesrepublik

# JWT / Auth
SECRET_KEY=dev-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (JSON-Array für mehrere Origins)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Magic-Link / OAuth Redirect
FRONTEND_BASE_URL=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:8000/api

# SMTP — Magic-Link-E-Mails und Kontaktformular (Zugangsdaten gemeinsam)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@localhost
# Empfänger nur für /api/kontakt
CONTACT_RECIPIENT=
# Empfänger für Playtest-Feedback-Benachrichtigungen (leer = kein Versand)
FEEDBACK_RECIPIENT=

# Admin-API (Basic-Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=

# Optional
DEBUG=true
CONTENT_DIR=app/content

# OpenAPI-/App-Titel (optional; Standard: "Bundesrepublik API")
# APP_NAME=Bundesrepublik API

# Secure-Flag für Refresh-Token-Cookies (optional).
# Nicht gesetzt: automatisch wie "nicht DEBUG" (lokal oft false, Prod true).
# Explizit setzen bei TLS nur hinter Reverse-Proxy oder lokalem HTTP-Test:
# COOKIE_SECURE=true
# COOKIE_SECURE=false

# --- Produktion (Docker Compose auf dem Server, siehe docs/deployment.md) ---
# Die folgenden Variablen werden typischerweise in der Server-.env neben
# docker-compose.prod.yml gesetzt (nicht alle sind für lokales .env nötig).
#
# PostgreSQL (nur für Compose / Doku — die App nutzt DATABASE_URL)
# POSTGRES_DB=politikpraxis
# POSTGRES_USER=pp_user
# POSTGRES_PASSWORD=<sicheres-passwort>
#
# DATABASE_URL=postgresql+asyncpg://pp_user:<pass>@db:5432/politikpraxis
# SECRET_KEY=<starkes-geheimnis>
# DEBUG=false
# CORS_ORIGINS=["https://politikpraxis.de","https://www.politikpraxis.de"]
# FRONTEND_BASE_URL=https://www.politikpraxis.de
# PUBLIC_API_BASE_URL=https://www.politikpraxis.de/api
#
# Frontend-Build (Vite, Build-Arg — nicht von FastAPI gelesen):
# VITE_REGISTRATION_NUMBER=<HRB …>
