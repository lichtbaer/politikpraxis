# Root-.env — von docker-compose*.yml eingelesen (Variablen-Substitution).
# Kopie nach .env anlegen und Werte setzen. Niemals echte Secrets committen.
# Vollständige Backend-Liste für lokales uvicorn: backend/.env.example
# Deployment-Schritte: docs/deployment.md

# =============================================================================
# A) Lokaler Stack — docker-compose.yml und docker-compose.dev.yml
# =============================================================================

# --- PostgreSQL (Compose-Service db) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me         # z.B. openssl rand -base64 24
POSTGRES_DB=bundesrepublik

# --- Backend (nur Teil der Werte kommen aus dieser .env) ---
# Mindestens 32 Zeichen (Prod), z.B.: openssl rand -hex 32
SECRET_KEY=
# Bei docker-compose.yml mit DEBUG=false erforderlich (Validierung in app.config).
# Hinweis: docker-compose.yml reicht ADMIN_PASSWORD aktuell nicht an den Container durch —
# für strengen Prod-Modus im Container ggf. compose anpassen oder DEBUG=true nur lokal.
ADMIN_PASSWORD=                     # z.B. openssl rand -base64 24
DEBUG=false

# Fest in den Compose-Dateien gesetzt (nicht über diese .env):
#   docker-compose.yml: CORS_ORIGINS, FRONTEND_BASE_URL, PUBLIC_API_BASE_URL
#   docker-compose.dev.yml: DEBUG=true, CORS_ORIGINS, kein FRONTEND_/PUBLIC_API_ im Backend-Block
# Weitere Backend-Variablen (ALGORITHM, TOKEN-Laufzeiten, CONTENT_DIR, SMTP, …): siehe
# backend/.env.example — sie wirken im Container nur, wenn du sie in environment: ergänzt.

# =============================================================================
# B) Produktion — docker-compose.prod.yml (Server-.env im Projektverzeichnis)
# =============================================================================

# PostgreSQL
# POSTGRES_DB=politikpraxis
# POSTGRES_USER=pp_user
# POSTGRES_PASSWORD=<sicheres-passwort>

# App (Host „db“ = Compose-Service-Name)
# DATABASE_URL=postgresql+asyncpg://pp_user:<pass>@db:5432/politikpraxis

# SECRET_KEY=<starkes-geheimnis>, z.B. openssl rand -hex 32

# JSON-Array-String; Apex + www, falls beide vorkommen:
# CORS_ORIGINS=["https://example.de","https://www.example.de"]
# FRONTEND_BASE_URL=https://www.example.de
# PUBLIC_API_BASE_URL=https://www.example.de/api

# DEBUG=false

# SMTP (Magic-Link, Kontakt)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM=
# CONTACT_RECIPIENT=

# Admin-API (Basic-Auth)
# ADMIN_USER=admin
# ADMIN_PASSWORD=

# Frontend-Build (nur Build-Arg / Compose-Substitution, landet im Browser-Bundle)
# VITE_REGISTRATION_NUMBER=

# Details (SSL, nginx, CI): docs/deployment.md
