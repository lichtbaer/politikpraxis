# Datenbank (PostgreSQL mit asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bundesrepublik

# JWT / Auth
SECRET_KEY=dev-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (JSON-Array für mehrere Origins)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Admin-API (Basic-Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=

# Optional
DEBUG=true
CONTENT_DIR=app/content

# Kontaktformular (SMTP — nur in .env, nie im Code committen)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
CONTACT_RECIPIENT=
